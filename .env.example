ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Backend selection (default: sdk)
# - sdk:           Anthropic Python SDK
# - cli:           local `claude` CLI as subprocess (uses subscription, not API quota)
# - cli-no-tools:  baseline for ablation comparison — model alone, no MCP
ANTHROPIC_BACKEND=sdk

# Optional: GitHub token to raise rate limit from 60/hr to 5000/hr during scrape
GH_TOKEN=
