      "releaseNotes": {
        "releaseNotesTooltip": "<div><span class=\"tooltip-title\">What's new in DeepStream 9.0:</span><ul><li>New AI capabilities and tools: DeepStream Coding Agent, Cosmos Reason 2 VLM</li><li>Support for RTX 4500 pro GPUs and latest Triton on x86 and JP 7.1</li><li>Built\u2011in observability with Open Telemetry, Prometheus metrics, and REST APIs for health checkpoints</li><li>Accuracy improvements for Reference Apps - MV3DT, MaskTracker, Pose Estimation</li><li>Smart Recording via Pyservicemaker</li></ul><a href=\"https://docs.nvidia.com/metropolis/deepstream/dev-guide/text/DS_Release_notes.html#whats-new\" target=\"_blank\" class=\"tooltip-link\">Open Release Notes</a></div>",
        "releaseNotesURL": "https://docs.nvidia.com/metropolis/deepstream/dev-guide/text/DS_Release_notes.html#whats-new",
        "releaseNotesDownload": false
      },
      "releaseMessage": "DeepStream SDK provides a complete streaming analytics toolkit for situational awareness through computer vision, intelligent video analytics (IVA) and multi-sensor processing.",
